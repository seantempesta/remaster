!checkpoints/nafnet_w32_mid4/*.onnx

# Exclude large/unnecessary files
tools/
data/
*.mkv
*.mp4
*.avi
__pycache__/
*.pyc
.git/
reference-code/vapoursynth/
reference-code/TensorRT/
reference-code/torch-tensorrt/
reference-code/TensorRT-Model-Optimizer/
